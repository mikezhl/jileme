generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageType {
  TEXT
  TRANSCRIPT
  AI_ANALYSIS
  AI_SUMMARY
}

enum AnalysisEventType {
  REALTIME_TRIGGER
  FINAL_SUMMARY_TRIGGER
}

enum RoomStatus {
  ACTIVE
  ENDED
}

enum TranscriptionProvider {
  DEEPGRAM
  DASHSCOPE
}

enum RoomVoiceSource {
  USER
  SYSTEM
}

model Room {
  id                             String                @id @default(cuid())
  roomId                         String                @unique
  name                           String?
  status                         RoomStatus            @default(ACTIVE)
  isPublic                       Boolean               @default(false)
  analysisEnabled                Boolean               @default(true)
  voiceSourcePreference          RoomVoiceSource?
  transcriptionProviderPreference TranscriptionProvider?
  endedAt                        DateTime?
  createdById                    String?
  createdBy                      User?                 @relation("CreatedRooms", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt                      DateTime              @default(now())
  updatedAt                      DateTime              @updatedAt
  messages                       Message[]
  participants                   RoomParticipant[]
  analysisEvents                 RoomAnalysisEvent[]
  analysisState                  RoomAnalysisState?
}

model Message {
  id            String      @id @default(cuid())
  roomRefId     String
  room          Room        @relation(fields: [roomRefId], references: [id], onDelete: Cascade)
  type          MessageType
  externalRef   String?     @unique
  senderName    String
  senderUserId  String?
  senderUser    User?       @relation(fields: [senderUserId], references: [id], onDelete: SetNull)
  participantId String?
  content       String
  createdAt     DateTime    @default(now())

  @@index([roomRefId, createdAt])
}

model User {
  id                         String                                @id @default(cuid())
  username                   String                                @unique
  passwordHash               String
  createdAt                  DateTime                              @default(now())
  updatedAt                  DateTime                              @updatedAt
  sessions                   Session[]
  createdRooms               Room[]                                @relation("CreatedRooms")
  roomParticipants           RoomParticipant[]
  messages                   Message[]
  livekitCredentials         UserLivekitCredentials?
  transcriptionCredentials   UserTranscriptionProviderCredential[]
  providerPreference         UserProviderPreference?
  llmKeys                    UserLlmKeys?
  usageStats                 UserUsageStats?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  lastSeenAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model RoomParticipant {
  id        String   @id @default(cuid())
  roomRefId String
  room      Room     @relation(fields: [roomRefId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@unique([roomRefId, userId])
  @@index([userId, joinedAt])
}

model UserLivekitCredentials {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  livekitUrlEncrypted     String?
  livekitApiKeyEncrypted  String?
  livekitApiSecretEncrypted String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model UserTranscriptionProviderCredential {
  id                    String                @id @default(cuid())
  userId                String
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider              TranscriptionProvider
  configEncrypted       String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([userId, provider])
  @@index([provider, updatedAt])
}

model UserProviderPreference {
  id                           String                 @id @default(cuid())
  userId                       String                 @unique
  user                         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultTranscriptionProvider TranscriptionProvider?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
}

model UserLlmKeys {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  baseUrlEncrypted String?
  apiKeyEncrypted  String?
  modelEncrypted   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UserUsageStats {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceUserDurationMs     BigInt   @default(0)
  voicePlatformDurationMs BigInt   @default(0)
  llmUserTokens           BigInt   @default(0)
  llmPlatformTokens       BigInt   @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model RoomAnalysisEvent {
  id         String            @id @default(cuid())
  roomRefId  String
  room       Room              @relation(fields: [roomRefId], references: [id], onDelete: Cascade)
  eventType  AnalysisEventType
  messageId  String?
  dedupeKey  String            @unique
  createdAt  DateTime          @default(now())
  processedAt DateTime?

  @@index([processedAt, createdAt])
  @@index([roomRefId, createdAt])
}

model RoomAnalysisState {
  roomRefId            String   @id
  room                 Room     @relation(fields: [roomRefId], references: [id], onDelete: Cascade)
  lastRealtimeMessageAt DateTime?
  lastRealtimeMessageId String?
  lastFinalSummaryAt    DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
