# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Docker Compose database and app port settings.
# `POSTGRES_*` config is used by the `postgres` service.
# `APP_PORT` controls the app port on both the host and inside the container.
# Change `APP_PORT` if port 3000 is already occupied on the server.
POSTGRES_DB="jileme"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_PORT="5432"
APP_PORT="3000"

# Direct runtime database URL for running the app outside Docker.
# When using `docker compose`, the `app` service overrides DATABASE_URL internally to:
# `postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public`
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jileme?schema=public"

# ------------------------------------------------------------
# Credential source mode (false | true | full)
# false: room voice always uses platform LiveKit. When transcription is enabled, it also uses the
#        platform transcription provider selected by TRANSCRIPTION_PROVIDER. User voice keys are ignored.
# true : room voice prefers a complete room-owner bundle. If the owner has complete LiveKit credentials and,
#        when transcription is enabled, valid credentials for their default transcription provider, that
#        user-owned voice bundle is used. Otherwise voice falls back to the complete platform bundle.
#        The room runtime still chooses one voice source and never mixes platform and user voice keys.
#        Other groups such as analysis LLM may also fall back to complete system config.
# full : room voice requires a complete user-owned room-owner bundle. Platform voice fallback is disabled,
#        so the owner must fully configure LiveKit and, when transcription is enabled, their default
#        transcription provider. Other groups also stop falling back to system config.
# ------------------------------------------------------------
USER_PROVIDER_KEYS_MODE="true"

# ------------------------------------------------------------
# Room speaker switch feature flag
# false: one account speaks only as itself in a room
# true : allow toggling between username and usernameBot on one device
# ------------------------------------------------------------
ROOM_SPEAKER_SWITCH_ENABLED="false"

# ------------------------------------------------------------
# Homepage footer text
# ------------------------------------------------------------
HOME_PAGE_FOOTER_TEXT=""

# ------------------------------------------------------------
# Platform default LiveKit credentials
# Used whenever room voice resolves to the platform LiveKit bundle
# This is always true when USER_PROVIDER_KEYS_MODE is false, and is the fallback path when it is true
# ------------------------------------------------------------
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="your_livekit_api_key"
LIVEKIT_API_SECRET="your_livekit_api_secret"

# ------------------------------------------------------------
# Transcriber worker controls
# ------------------------------------------------------------
LIVEKIT_TRANSCRIBER_ENABLED="true"
LIVEKIT_TRANSCRIBER_AGENT_NAME="transcriber"
# Optional: auto-started dynamic worker idle recycle timeout (ms)
TRANSCRIBER_WORKER_IDLE_TIMEOUT_MS="600000"
# Optional: dynamic worker startup timeout before marking failure (ms)
TRANSCRIBER_WORKER_STARTUP_TIMEOUT_MS="30000"
# Optional: split transcript utterance after this much silence (ms)
TRANSCRIPT_UTTERANCE_GAP_MS="2000"

# ------------------------------------------------------------
# Conversation analysis worker controls
# ------------------------------------------------------------
# Polling interval for analysis-event queue
ANALYZER_QUEUE_POLL_INTERVAL_MS="1000"
# Realtime analysis trigger debounce after latest room message
ANALYZER_REALTIME_DEBOUNCE_MS="10000"
# Max pending events processed per polling cycle
ANALYZER_EVENT_BATCH_SIZE="200"
# Max compacted history turns included in realtime analysis payload
ANALYZER_HISTORY_TURN_LIMIT="18"
# Optional: analyzer worker startup timeout before marking failure (ms)
ANALYZER_WORKER_STARTUP_TIMEOUT_MS="30000"
# Optional: retry interval after schema-missing failure (ms)
ANALYZER_SCHEMA_RETRY_MS="60000"

# ------------------------------------------------------------
# Conversation LLM runtime (mock first)
# ------------------------------------------------------------
# mock | openai-compatible
CONVERSATION_LLM_PROVIDER="mock"
# prompt style key for realtime analysis mode
CONVERSATION_REALTIME_PROMPT_STYLE="default_cn"
# prompt style key for final summary mode
CONVERSATION_SUMMARY_PROMPT_STYLE="default_cn"

# ------------------------------------------------------------
# Platform default OpenAI-compatible LLM config
# Required when CONVERSATION_LLM_PROVIDER="openai-compatible"
# and USER_PROVIDER_KEYS_MODE is false
# Optional fallback when USER_PROVIDER_KEYS_MODE is true
# Ignored when USER_PROVIDER_KEYS_MODE is full
# Use a base URL such as https://api.openai.com/v1
# ------------------------------------------------------------
CONVERSATION_LLM_OPENAI_BASE_URL="https://api.openai.com/v1"
CONVERSATION_LLM_OPENAI_API_KEY="your_openai_compatible_api_key"
CONVERSATION_LLM_OPENAI_MODEL="gpt-4o-mini"

# ------------------------------------------------------------
# Platform key usage limits per room owner
# These limits apply only when a room falls back to platform keys.
# User-owned keys are not capped by these env settings.
# Set to 0 to disable a limit.
# ------------------------------------------------------------
PLATFORM_TRANSCRIPTION_LIMIT_MINUTES_PER_USER="120"
PLATFORM_LLM_LIMIT_TOKENS_PER_USER="5000000"

# ------------------------------------------------------------
# Platform default transcription provider for voice mode
# Used whenever room voice resolves to the platform transcription bundle
# This is always true when USER_PROVIDER_KEYS_MODE is false, and is the fallback path when it is true
# deepgram | dashscope
# ------------------------------------------------------------
TRANSCRIPTION_PROVIDER="deepgram"

# ------------------------------------------------------------
# Platform default Deepgram key and STT options
# Used when TRANSCRIPTION_PROVIDER="deepgram"
# ------------------------------------------------------------
DEEPGRAM_API_KEY="your_deepgram_api_key"
DEEPGRAM_MODEL="nova-2"
DEEPGRAM_LANGUAGE="zh"
DEEPGRAM_INTERIM_RESULTS="true"
DEEPGRAM_PUNCTUATE="true"
DEEPGRAM_SMART_FORMAT="true"
DEEPGRAM_ENDPOINTING="25"
DEEPGRAM_PROFANITY_FILTER="false"
DEEPGRAM_FILLER_WORDS="false"
DEEPGRAM_NUMERALS="false"
DEEPGRAM_DETECT_LANGUAGE="false"
DEEPGRAM_NO_DELAY="true"
DEEPGRAM_DIARIZE="false"
DEEPGRAM_DICTATION="false"
DEEPGRAM_SAMPLE_RATE="16000"
DEEPGRAM_NUM_CHANNELS="1"
DEEPGRAM_MIP_OPT_OUT="false"

# ------------------------------------------------------------
# Platform default DashScope Qwen realtime options
# Used when TRANSCRIPTION_PROVIDER="dashscope"
# Beijing API keys must use `wss://dashscope.aliyuncs.com/api-ws/v1/realtime`
# Singapore API keys must use `wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime`
# ------------------------------------------------------------
DASHSCOPE_API_KEY="your_dashscope_api_key"
DASHSCOPE_REALTIME_URL="wss://dashscope.aliyuncs.com/api-ws/v1/realtime"
DASHSCOPE_REALTIME_MODEL="qwen3-asr-flash-realtime"
DASHSCOPE_REALTIME_LANGUAGE="zh"
DASHSCOPE_REALTIME_AUDIO_FORMAT="pcm"
DASHSCOPE_REALTIME_SAMPLE_RATE="16000"
DASHSCOPE_REALTIME_SERVER_VAD="true"
DASHSCOPE_REALTIME_SILENCE_DURATION_MS="400"

# ------------------------------------------------------------
# Auth email verification via SMTP
# Replace with your SMTP provider settings
# ------------------------------------------------------------
AUTH_EMAIL_CODE_TTL_MINUTES="10"
AUTH_EMAIL_CODE_RESEND_SECONDS="60"
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password"
SMTP_FROM_EMAIL="no-reply@example.com"
SMTP_FROM_NAME="Your App Name"

# ------------------------------------------------------------
# LINUX DO Connect OAuth
# Leave any value blank to disable this sign-in option.
# `LINUX_DO_CONNECT_REDIRECT_URI` should point to
# `/api/auth/linux-do-connect/callback` on your deployed origin.
# ------------------------------------------------------------
LINUX_DO_CONNECT_CLIENT_ID=""
LINUX_DO_CONNECT_CLIENT_SECRET=""
LINUX_DO_CONNECT_REDIRECT_URI=""

# ------------------------------------------------------------
# App security
# ------------------------------------------------------------
APP_ENCRYPTION_SECRET="replace_with_a_random_32_plus_char_secret"
SESSION_TTL_HOURS="24"
